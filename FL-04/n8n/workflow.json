            {
              "id": "t",
              "name": "topic",
              "value": "Model Context Protocol primitives",
              "type": "string"
            },
            {
              "id": "u",
              "name": "source_url",
              "value": "https://modelcontextprotocol.io/specification/2025-06-18/server/tools",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "name": "Input",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        0,
        0
      ],
      "id": "node-2"
    },
    {
      "parameters": {
        "url": "={{ $('Input').item.json.source_url }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "text"
